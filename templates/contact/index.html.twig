{% extends 'base.html.twig' %}
{% block title %}Contact{% endblock %}

{% block body %}
<section class="section">
    <div class="contact-layout">

        {# Colonne gauche — texte #}
        <div class="contact-left">
            <span class="section-eyebrow">Contact</span>
            <h1 class="contact-title">Parlons de<br><em style="font-style:normal;color:var(--color-accent)">votre projet.</em></h1>
            <p class="contact-desc">
                Développement sur mesure, question sur l'algo, accès premium — je réponds sous 24h.
            </p>

            <div class="contact-infos">
                <a href="mailto:contact@devtrade.fr" class="contact-info-item">
                    <div class="contact-info-icon">✉</div>
                    <div>
                        <div class="contact-info-label">Email</div>
                        <div class="contact-info-value">contact@devtrade.fr</div>
                    </div>
                </a>
                <div class="contact-info-item">
                    <div class="contact-info-icon">⏱</div>
                    <div>
                        <div class="contact-info-label">Délai de réponse</div>
                        <div class="contact-info-value">Sous 24h</div>
                    </div>
                </div>
                <div class="contact-info-item">
                    <div class="contact-info-icon">🌍</div>
                    <div>
                        <div class="contact-info-label">Disponibilité</div>
                        <div class="contact-info-value">France — Remote</div>
                    </div>
                </div>
            </div>
        </div>

        {# Colonne droite — formulaire #}
        <div class="contact-right">

            {% if success %}
                <div class="contact-success">
                    <div class="contact-success__icon">✓</div>
                    <div>
                        <strong>Message envoyé !</strong>
                        <p>Je vous réponds sous 24h à {{ app.request.request.get('email') }}.</p>
                    </div>
                </div>
            {% else %}

                {% if error %}
                    <div class="flash flash--danger" style="margin-bottom:1.5rem;max-width:100%">{{ error }}</div>
                {% endif %}

                <form method="post" class="contact-form">

                    <div class="contact-form__row">
                        <div class="form-group">
                            <label class="form-label">Nom *</label>
                            <input type="text" name="name" class="form-control" placeholder="Jean Dupont" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email *</label>
                            <input type="email" name="email" class="form-control" placeholder="votre@email.com" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Sujet</label>
                        <select name="subject" class="form-control">
                            <option value="">Choisir un sujet</option>
                            <option>Demande de devis — développement</option>
                            <option>Question sur l'algo de trading</option>
                            <option>Accès Premium documentation</option>
                            <option>Partenariat</option>
                            <option>Autre</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Message *</label>
                        <textarea name="message" class="form-control" rows="6"
                            placeholder="Décrivez votre projet ou votre question..."
                            required style="resize:vertical"></textarea>
                    </div>

                    <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;padding:0.85rem">
                        Envoyer le message
                    </button>

                </form>
            {% endif %}

        </div>
    </div>
</section>
{% endblock %}

{% block stylesheets %}
<style>
.contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 6rem;
    align-items: start;
}

.contact-title {
    margin-bottom: 1.2rem;
    line-height: 1.05;
}

.contact-desc {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 3rem;
    max-width: 380px;
}

.contact-infos {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
}

.contact-info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
    transition: opacity var(--transition);
}
a.contact-info-item:hover { opacity: 0.75; }

.contact-info-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-accent-dim);
    border: 0.5px solid var(--color-accent-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
}

.contact-info-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    margin-bottom: 2px;
}

.contact-info-value {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 400;
}

.contact-right {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
}

.contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

.contact-success {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    padding: 2rem;
    background: var(--color-accent-dim);
    border: 0.5px solid var(--color-accent-border);
    border-radius: var(--radius-lg);
}

.contact-success__icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #080B10;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
}

.contact-success strong { color: var(--color-accent); display: block; margin-bottom: 4px; }
.contact-success p { font-size: 13.5px; color: var(--color-text-muted); }

@media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
    .contact-form__row { grid-template-columns: 1fr; }
}
</style>
{% endblock %}
