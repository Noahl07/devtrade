{% extends 'base.html.twig' %}

{% block title %}{{ project.title }}{% endblock %}
{% block meta_description %}{{ project.shortDesc }}{% endblock %}

{% block body %}
<section class="section">

    <nav class="breadcrumb" style="margin-bottom:2.5rem">
        <a href="{{ path('app_portfolio') }}" class="breadcrumb__item">
            <i class="bi bi-briefcase"></i> Portfolio
        </a>
        <i class="bi bi-chevron-right breadcrumb__sep"></i>
        <span class="breadcrumb__item breadcrumb__item--active">{{ project.title }}</span>
    </nav>

    <div class="project-detail-layout">

        {# Contenu principal #}
        <div class="project-detail-main">

            <div class="project-detail-header">
                <span class="project-detail-type">{{ project.type|upper }}</span>
                <h1 class="project-detail-title">{{ project.title }}</h1>
                <p class="project-detail-lead">{{ project.shortDesc }}</p>
            </div>

            {% if project.imageUrl %}
                <div class="project-detail-image">
                    <img src="{{ project.imageUrl }}" alt="{{ project.title }}">
                </div>
            {% endif %}

            <div class="prose project-detail-content">
                {{ project.description|raw }}
            </div>

        </div>

        {# Sidebar infos #}
        <aside class="project-detail-sidebar">

            {# Stack #}
            <div class="project-sidebar-card">
                <div class="project-sidebar-card__title">
                    <i class="bi bi-stack"></i> Stack technique
                </div>
                <div class="project-sidebar-tags">
                    {% for tech in project.techStack %}
                        <span class="tag tag--accent">{{ tech }}</span>
                    {% endfor %}
                </div>
            </div>

            {# Liens #}
            {% if project.projectUrl or project.githubUrl %}
                <div class="project-sidebar-card">
                    <div class="project-sidebar-card__title">
                        <i class="bi bi-link-45deg"></i> Liens
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px">
                        {% if project.projectUrl %}
                            <a href="{{ project.projectUrl }}" target="_blank" class="btn btn--outline-accent" style="font-size:13px;justify-content:center">
                                <i class="bi bi-box-arrow-up-right"></i> Voir le projet live
                            </a>
                        {% endif %}
                        {% if project.githubUrl %}
                            <a href="{{ project.githubUrl }}" target="_blank" class="btn btn--ghost" style="font-size:13px;justify-content:center">
                                <i class="bi bi-github"></i> Voir sur GitHub
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# CTA devis #}
            <div class="project-sidebar-card project-sidebar-card--cta">
                <div class="project-sidebar-card__title">
                    <i class="bi bi-chat-dots"></i> Projet similaire ?
                </div>
                <p style="font-size:13px;font-weight:300;margin-bottom:1rem">
                    Discutons de votre projet — devis gratuit et réponse sous 24h.
                </p>
                <a href="{{ path('app_contact') }}" class="btn btn--primary" style="width:100%;justify-content:center;font-size:13px">
                    <i class="bi bi-send"></i> Demander un devis
                </a>
            </div>

        </aside>

    </div>

    {# Navigation retour #}
    <div style="margin-top:3rem;padding-top:2rem;border-top:0.5px solid var(--color-border)">
        <a href="{{ path('app_portfolio') }}" class="btn btn--ghost">
            <i class="bi bi-arrow-left"></i> Tous les projets
        </a>
    </div>

</section>
{% endblock %}

{% block stylesheets %}
<style>
.breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
}
.breadcrumb__item { color: var(--color-text-faint); transition: color var(--transition); }
a.breadcrumb__item:hover { color: var(--color-accent); }
.breadcrumb__item--active { color: var(--color-text-muted); }
.breadcrumb__sep { color: var(--color-text-faint); font-size: 10px; }

.project-detail-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
}

.project-detail-type {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-weight: 500;
    display: block;
    margin-bottom: 0.8rem;
}

.project-detail-title { margin-bottom: 1rem; }

.project-detail-lead {
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 2.5rem;
}

.project-detail-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--color-border);
    margin-bottom: 2.5rem;
    background: var(--color-bg-2);
}
.project-detail-image img {
    width: 100%;
    display: block;
}

.project-sidebar-card {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
}

.project-sidebar-card--cta {
    background: var(--color-accent-dim);
    border-color: var(--color-accent-border);
}

.project-sidebar-card__title {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 6px;
}
.project-sidebar-card--cta .project-sidebar-card__title { color: var(--color-accent); }

.project-sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

/* Prose styles (partagés avec les articles doc) */
.prose { font-size: 15.5px; line-height: 1.8; color: rgba(232,234,240,0.8); }
.prose h2 { font-size: 1.4rem; margin: 2rem 0 1rem; color: #F0F2F7; border-bottom: 0.5px solid var(--color-border); padding-bottom: 0.5rem; }
.prose h3 { font-size: 1.1rem; margin: 1.5rem 0 0.8rem; color: #F0F2F7; }
.prose p { margin-bottom: 1.2rem; }
.prose strong { color: #F0F2F7; font-weight: 500; }
.prose ul { padding-left: 1.5rem; margin-bottom: 1.2rem; display: flex; flex-direction: column; gap: 0.4rem; }
.prose li::marker { color: var(--color-accent); }

@media (max-width: 900px) {
    .project-detail-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .project-detail-sidebar { order: -1; }
}
</style>
{% endblock %}
