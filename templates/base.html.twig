<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {# ── SEO ── #}
    <title>{% block title %}{{ site_name }}{% endblock %} — dev.trade</title>
    <meta name="description" content="{% block meta_description %}{{ site_description }}{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <link rel="canonical" href="{% block canonical %}{{ app.request.uri }}{% endblock %}">

    {# ── Open Graph ── #}
    <meta property="og:type"        content="{% block og_type %}website{% endblock %}">
    <meta property="og:site_name"   content="dev.trade">
    <meta property="og:title"       content="{% block og_title %}{% block title_raw %}{{ site_name }}{% endblock %} — dev.trade{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ site_description }}{% endblock %}">
    <meta property="og:url"         content="{{ app.request.uri }}">
    <meta property="og:image"       content="{% block og_image %}{{ absolute_url('/images/og-default.png') }}{% endblock %}">
    <meta property="og:locale"      content="fr_FR">

    {# ── Twitter Card ── #}
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="{% block twitter_title %}{{ site_name }} — dev.trade{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{{ site_description }}{% endblock %}">
    <meta name="twitter:image"       content="{% block twitter_image %}{{ absolute_url('/images/og-default.png') }}{% endblock %}">

    {# ── Fonts ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

    {# ── Bootstrap Icons ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {# ── CSS via Webpack Encore ── #}
    {{ encore_entry_link_tags('app') }}

    {% block stylesheets %}{% endblock %}

    {# ── Favicon ── #}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%233EB489'/><text y='24' x='4' font-size='22' fill='%23080B10' font-weight='bold'>dt</text></svg>">
</head>
<body class="{% block body_class %}{% endblock %}">

    {% include 'components/_nav.html.twig' %}

    {% if app.flashes|length > 0 %}
        <div class="flash-container">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash--{{ type }}">
                        <span>{{ message }}</span>
                        <button class="flash__close" onclick="this.parentElement.remove()">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    <main class="main-content">
        {% block body %}{% endblock %}
    </main>

    {% include 'components/_footer.html.twig' %}

    {{ encore_entry_script_tags('app') }}
    {{ encore_entry_script_tags('custom-select') }}

    {% block javascripts %}{% endblock %}

</body>
</html>
