{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}
{% block body_class %}page--auth{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">

        <div class="auth-card__header">
            <a href="{{ path('app_home') }}" class="auth-card__logo">
                dev<span style="color:var(--color-accent)">.</span>trade
            </a>
            <h1 class="auth-card__title">Mot de passe oublié</h1>
            <p class="auth-card__sub">Entrez votre email — nous vous enverrons un lien de réinitialisation.</p>
        </div>

        {% if success %}
            <div class="flash flash--success" style="max-width:100%;margin-bottom:1.5rem">
                <i class="bi bi-check-circle"></i>
                Si un compte existe avec cet email, vous recevrez un lien sous quelques minutes.
            </div>
        {% endif %}

        {% if error %}
            <div class="flash flash--danger" style="max-width:100%;margin-bottom:1.5rem">{{ error }}</div>
        {% endif %}

        {% if not success %}
            <form method="post">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control"
                           placeholder="votre@email.com" autofocus required>
                </div>
                <button type="submit" class="btn btn--primary auth-form__submit">
                    <i class="bi bi-send"></i> Envoyer le lien
                </button>
            </form>
        {% endif %}

        <div class="auth-card__footer">
            <a href="{{ path('app_login') }}" class="auth-card__link">
                <i class="bi bi-arrow-left"></i> Retour à la connexion
            </a>
        </div>

    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.page--auth .main-content { display:flex; align-items:center; justify-content:center; min-height:calc(100vh - var(--nav-height)); padding:3rem var(--section-px); }
.auth-page { width:100%; max-width:440px; }
.auth-card { background:var(--color-bg-2); border:0.5px solid var(--color-border); border-radius:var(--radius-xl); padding:2.8rem; }
.auth-card__header { margin-bottom:2rem; text-align:center; }
.auth-card__logo { font-family:var(--font-display); font-weight:800; font-size:1.3rem; color:#F0F2F7; display:inline-block; margin-bottom:1.5rem; letter-spacing:-0.02em; }
.auth-card__title { font-size:1.5rem; margin-bottom:0.5rem; }
.auth-card__sub { font-size:14px; font-weight:300; }
.auth-form__submit { width:100%; justify-content:center; padding:0.8rem; font-size:15px; margin-top:0.5rem; }
.auth-card__footer { margin-top:1.8rem; text-align:center; font-size:13.5px; color:var(--color-text-faint); }
.auth-card__link { color:var(--color-accent); font-weight:500; }
</style>
{% endblock %}
