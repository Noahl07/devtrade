{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe{% endblock %}
{% block body_class %}page--auth{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">

        <div class="auth-card__header">
            <a href="{{ path('app_home') }}" class="auth-card__logo">
                dev<span style="color:var(--color-accent)">.</span>trade
            </a>
            <h1 class="auth-card__title">Nouveau mot de passe</h1>
            <p class="auth-card__sub">Choisissez un mot de passe sécurisé d'au moins 8 caractères.</p>
        </div>

        {% if error %}
            <div class="flash flash--danger" style="max-width:100%;margin-bottom:1.5rem">{{ error }}</div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="token" value="{{ token }}">

            <div class="form-group">
                <label class="form-label">Nouveau mot de passe</label>
                <input type="password" name="password" class="form-control"
                       placeholder="8 caractères minimum" autofocus required>
            </div>

            <div class="form-group">
                <label class="form-label">Confirmer le mot de passe</label>
                <input type="password" name="confirm" class="form-control"
                       placeholder="Répétez le mot de passe" required>
            </div>

            <button type="submit" class="btn btn--primary auth-form__submit">
                <i class="bi bi-check-lg"></i> Enregistrer le mot de passe
            </button>
        </form>

    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.page--auth .main-content { display:flex; align-items:center; justify-content:center; min-height:calc(100vh - var(--nav-height)); padding:3rem var(--section-px); }
.auth-page { width:100%; max-width:440px; }
.auth-card { background:var(--color-bg-2); border:0.5px solid var(--color-border); border-radius:var(--radius-xl); padding:2.8rem; }
.auth-card__header { margin-bottom:2rem; text-align:center; }
.auth-card__logo { font-family:var(--font-display); font-weight:800; font-size:1.3rem; color:#F0F2F7; display:inline-block; margin-bottom:1.5rem; letter-spacing:-0.02em; }
.auth-card__title { font-size:1.5rem; margin-bottom:0.5rem; }
.auth-card__sub { font-size:14px; font-weight:300; }
.auth-form__submit { width:100%; justify-content:center; padding:0.8rem; font-size:15px; margin-top:0.5rem; }
</style>
{% endblock %}
