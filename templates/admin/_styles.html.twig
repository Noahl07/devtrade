<style>
/* ── Admin layout ── */
.admin-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: calc(100vh - var(--nav-height));
}

.admin-sidebar {
    background: var(--color-bg-2);
    border-right: 0.5px solid var(--color-border);
    padding: 1.5rem 0;
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
}

.admin-sidebar__logo a {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    color: #F0F2F7;
    padding: 0 1.5rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
    margin-bottom: 1rem;
}
.admin-sidebar__logo small {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-family: var(--font-body);
    font-weight: 500;
}

.admin-nav { padding: 0 0.75rem; display: flex; flex-direction: column; gap: 1.5rem; }
.admin-nav__group { display: flex; flex-direction: column; gap: 2px; }
.admin-nav__label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
    padding: 0 0.75rem;
    margin-bottom: 4px;
}
.admin-nav__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 13.5px;
    color: var(--color-text-muted);
    transition: var(--transition);
    text-decoration: none;
}
.admin-nav__item:hover { background: rgba(255,255,255,0.05); color: var(--color-text); }
.admin-nav__item--active { background: var(--color-accent-dim); color: var(--color-accent); }
.admin-nav__item--danger { color: #e05555; }
.admin-nav__item--danger:hover { background: rgba(220,80,80,0.08); }

/* ── Admin main ── */
.admin-main { padding: 2.5rem; overflow-y: auto; }

.admin-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
}
.admin-page-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #F0F2F7;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
}
.admin-page-title i { color: var(--color-accent); }
.admin-date { font-size: 13px; color: var(--color-text-faint); }

/* ── Stats ── */
.admin-stats {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}
.admin-stat {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
}
.admin-stat__icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
}
.admin-stat__icon--blue { background: rgba(62,130,200,0.12); color: #5b9bd5; border: 0.5px solid rgba(62,130,200,0.2); }
.admin-stat__icon--gold { background: var(--color-gold-dim); color: var(--color-gold); border: 0.5px solid rgba(212,169,75,0.2); }
.admin-stat__icon--green { background: var(--color-accent-dim); color: var(--color-accent); border: 0.5px solid var(--color-accent-border); }
.admin-stat__icon--orange { background: rgba(220,140,50,0.1); color: #e09040; border: 0.5px solid rgba(220,140,50,0.2); }
.admin-stat__icon--accent { background: var(--color-accent-dim); color: var(--color-accent); border: 0.5px solid var(--color-accent-border); }

.admin-stat__val { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: #F0F2F7; line-height: 1; }
.admin-stat__label { font-size: 11.5px; color: var(--color-text-faint); margin-top: 2px; }

/* ── Cards ── */
.admin-card {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}
.admin-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.5rem;
    border-bottom: 0.5px solid var(--color-border);
}
.admin-card__header h3 {
    font-size: 14px;
    font-weight: 600;
    color: #F0F2F7;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
}
.admin-card__header h3 i { color: var(--color-accent); }
.admin-card > *:not(.admin-card__header):not(table) { padding: 1.5rem; }

.admin-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.admin-link { font-size: 12.5px; color: var(--color-accent); }

/* ── Table ── */
.admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
}
.admin-table th {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    padding: 0.7rem 1.2rem;
    border-bottom: 0.5px solid var(--color-border);
    background: rgba(255,255,255,0.02);
    text-align: left;
    font-weight: 500;
}
.admin-table td {
    padding: 0.85rem 1.2rem;
    border-bottom: 0.5px solid var(--color-border);
    color: var(--color-text-muted);
    vertical-align: middle;
}
.admin-table tr:last-child td { border-bottom: none; }
.admin-table tr:hover td { background: rgba(255,255,255,0.015); }
.text-muted { color: var(--color-text-faint) !important; }
.text-center { text-align: center; }

/* ── Badges ── */
.admin-badge {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(255,255,255,0.06);
    color: var(--color-text-faint);
    border: 0.5px solid var(--color-border);
    white-space: nowrap;
}
.admin-badge--gold { background: var(--color-gold-dim); color: var(--color-gold); border-color: rgba(212,169,75,0.25); }
.admin-badge--green { background: var(--color-accent-dim); color: var(--color-accent); border-color: var(--color-accent-border); }
.admin-badge--red { background: rgba(220,80,80,0.1); color: #e05555; border-color: rgba(220,80,80,0.2); }
.admin-badge--blue { background: rgba(62,130,200,0.1); color: #5b9bd5; border-color: rgba(62,130,200,0.2); }

/* ── Form admin ── */
.admin-form { max-width: 820px; }
.admin-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.admin-form-full { grid-column: 1 / -1; }

.admin-editor {
    background: var(--color-bg);
    border: 0.5px solid var(--color-border-md);
    border-radius: var(--radius-md);
    padding: 1rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 13.5px;
    line-height: 1.7;
    width: 100%;
    min-height: 400px;
    resize: vertical;
    outline: none;
    transition: border-color var(--transition);
}
.admin-editor:focus { border-color: rgba(62,180,137,0.4); }

.admin-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--color-text-muted);
    cursor: pointer;
}
.admin-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent);
    cursor: pointer;
}

/* ── Actions toolbar ── */
.admin-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
}

/* ── Delete button ── */
.btn--danger {
    background: rgba(220,80,80,0.1);
    color: #e05555;
    border: 0.5px solid rgba(220,80,80,0.2);
}
.btn--danger:hover { background: rgba(220,80,80,0.18); }

@media (max-width: 1100px) {
    .admin-stats { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { display: none; }
    .admin-grid-2 { grid-template-columns: 1fr; }
    .admin-stats { grid-template-columns: repeat(2, 1fr); }
}

/* ── Table scroll mobile ── */
.admin-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
}
.admin-table-wrap .admin-table {
    min-width: 600px;
}

@media (max-width: 600px) {
    .admin-main { padding: 1.2rem; }
    .admin-stats { grid-template-columns: 1fr 1fr; }
    .admin-topbar { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
}
</style>
