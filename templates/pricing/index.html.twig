{% extends 'base.html.twig' %}

{% block title %}Premium{% endblock %}
{% block meta_description %}Accédez à la documentation de trading complète, aux modules avancés ICT, Orderflow, Quantitatif et aux avancées exclusives de l'algo.{% endblock %}

{% block body %}

<section class="section pricing-section">

    {# ── Header ── #}
    <div class="pricing-header">
        <span class="section-eyebrow">Accès & Tarifs</span>
        <h1 class="pricing-title">Simple. Transparent. <em class="pricing-title__accent">Sans surprise.</em></h1>
        <p class="pricing-subtitle">
            Commencez gratuitement avec les bases du trading, passez Premium quand vous êtes prêt
            pour les concepts avancés et l'accès à l'algo.
        </p>
    </div>

    {# ── Cards ── #}
    <div class="pricing-grid">

        {# ── FREE ── #}
        <div class="pricing-card">
            <div class="pricing-card__header">
                <div class="pricing-card__badge pricing-card__badge--free">
                    <i class="bi bi-unlock-fill"></i> Gratuit
                </div>
                <div class="pricing-card__price">
                    <span class="pricing-card__amount">0€</span>
                    <span class="pricing-card__period">pour toujours</span>
                </div>
                <p class="pricing-card__desc">
                    Pour découvrir les marchés et poser des bases solides avant de trader.
                </p>
            </div>

            <ul class="pricing-card__features">
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check"></i>
                    <span>Accès à toute la documentation gratuite</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check"></i>
                    <span>Modules : Débuter, Analyse technique, ICT bases, Price Action, Psychologie, Macro</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check"></i>
                    <span>Plus de 40 articles structurés</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check"></i>
                    <span>Mises à jour du contenu gratuit</span>
                </li>
                <li class="pricing-card__feature pricing-card__feature--disabled">
                    <i class="bi bi-x-circle pricing-card__cross"></i>
                    <span>Modules avancés ICT, Orderflow, Quant...</span>
                </li>
                <li class="pricing-card__feature pricing-card__feature--disabled">
                    <i class="bi bi-x-circle pricing-card__cross"></i>
                    <span>Accès à l'algo de trading</span>
                </li>
                <li class="pricing-card__feature pricing-card__feature--disabled">
                    <i class="bi bi-x-circle pricing-card__cross"></i>
                    <span>Avancées & résultats en temps réel</span>
                </li>
            </ul>

            <div class="pricing-card__cta">
                {% if app.user %}
                    <a href="{{ path('app_documentation') }}" class="btn btn--ghost pricing-card__btn">
                        Accéder à la documentation
                    </a>
                {% else %}
                    <a href="{{ path('app_register') }}" class="btn btn--ghost pricing-card__btn">
                        <i class="bi bi-person-plus"></i> Créer un compte gratuit
                    </a>
                {% endif %}
            </div>
        </div>

        {# ── PREMIUM ── #}
        <div class="pricing-card pricing-card--premium">

            <div class="pricing-card__popular">Le plus populaire</div>

            <div class="pricing-card__header">
                <div class="pricing-card__badge pricing-card__badge--premium">
                    <i class="bi bi-star-fill"></i> Premium
                </div>
                <div class="pricing-card__early-bird">
                    <i class="bi bi-lightning-charge-fill"></i> Offre Early Bird — tarif réduit limité dans le temps
                </div>
                <div class="pricing-card__price">
                    <span class="pricing-card__amount pricing-card__amount--premium">Bientôt</span>
                    <span class="pricing-card__period">prix réduit à venir</span>
                </div>
                <p class="pricing-card__desc">
                    Pour les traders sérieux qui veulent aller jusqu'au bout — concepts experts,
                    algo et suivi en direct.
                </p>
            </div>

            <ul class="pricing-card__features">
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span><strong>Tout le contenu gratuit</strong> inclus</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Modules Premium : ICT Avancé, Orderflow & Footprint, Quantitatif, Risk Management, Algo Trading, Stratégies complètes</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Plus de 55 articles avancés supplémentaires</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Accès aux avancées & résultats de l'algo en temps réel</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Notifications à la sortie de l'algo de trading</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Nouveaux modules & articles en priorité</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Support direct par email</span>
                </li>
                <li class="pricing-card__feature">
                    <i class="bi bi-check-circle-fill pricing-card__check pricing-card__check--gold"></i>
                    <span>Réduction exclusive sur l'accès à l'algo à sa sortie</span>
                    <span class="pricing-card__limited-badge">
                        <i class="bi bi-hourglass-split"></i> Offre limitée
                    </span>
                </li>
            </ul>

            <div class="pricing-card__cta">
                {% if app.user and app.user.isPremium %}
                    <div class="pricing-card__already-premium">
                        <i class="bi bi-star-fill"></i> Vous êtes déjà Premium
                    </div>
                {% else %}
                    <a href="{{ path('app_contact') }}" class="btn btn--primary pricing-card__btn">
                        <i class="bi bi-envelope"></i> Nous contacter pour accéder
                    </a>
                    <p class="pricing-card__note">
                        Paiements automatisés disponibles prochainement via Stripe.
                    </p>
                {% endif %}
            </div>
        </div>

    </div>

    {# ── FAQ rapide ── #}
    <div class="pricing-faq">
        <h2 class="pricing-faq__title">Questions fréquentes</h2>
        <div class="pricing-faq__grid">
            <div class="pricing-faq__item">
                <h3 class="pricing-faq__q"><i class="bi bi-question-circle"></i> Puis-je tester avant de payer ?</h3>
                <p class="pricing-faq__a">Oui — le compte gratuit donne accès à plus de 40 articles sans limite de durée. Aucune CB requise.</p>
            </div>
            <div class="pricing-faq__item">
                <h3 class="pricing-faq__q"><i class="bi bi-question-circle"></i> Comment passer Premium ?</h3>
                <p class="pricing-faq__a">Contactez-nous via le formulaire de contact. Les paiements automatisés via Stripe seront disponibles prochainement.</p>
            </div>
            <div class="pricing-faq__item">
                <h3 class="pricing-faq__q"><i class="bi bi-question-circle"></i> L'algo est-il inclus dans le Premium ?</h3>
                <p class="pricing-faq__a">Les membres Premium auront accès aux avancées, résultats et à la sortie en avant-première. L'accès direct à l'algo fera l'objet d'une offre dédiée.</p>
            </div>
            <div class="pricing-faq__item">
                <h3 class="pricing-faq__q"><i class="bi bi-question-circle"></i> Le contenu est-il mis à jour ?</h3>
                <p class="pricing-faq__a">Oui, régulièrement. Les membres Premium reçoivent les nouveaux modules et articles en priorité.</p>
            </div>
        </div>
    </div>

</section>

{% endblock %}

{% block stylesheets %}
<style>

.pricing-section {
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 5rem;
    padding-bottom: 6rem;
}

/* ── Header ── */
.pricing-header {
    text-align: center;
    margin-bottom: 4rem;
}
.pricing-title {
    margin-bottom: 1rem;
}
.pricing-title__accent {
    font-style: normal;
    color: var(--color-accent);
}
.pricing-subtitle {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-muted);
}

/* ── Grid ── */
.pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 5rem;
}

/* ── Card ── */
.pricing-card {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    transition: border-color var(--transition);
}
.pricing-card:hover {
    border-color: var(--color-border-md);
}
.pricing-card--premium {
    border-color: rgba(212, 169, 75, 0.35);
    background: linear-gradient(160deg, rgba(212,169,75,0.04) 0%, var(--color-bg-2) 50%);
}
.pricing-card--premium:hover {
    border-color: rgba(212, 169, 75, 0.6);
}

/* Popular badge */
.pricing-card__popular {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-gold);
    color: #0a0d14;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 14px;
    border-radius: 100px;
    white-space: nowrap;
}

/* Header card */
.pricing-card__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.pricing-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    width: fit-content;
}
.pricing-card__badge--free {
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border: 0.5px solid var(--color-accent-border);
}
.pricing-card__badge--premium {
    background: var(--color-gold-dim);
    color: var(--color-gold);
    border: 0.5px solid rgba(212,169,75,0.3);
}

.pricing-card__early-bird {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 100px;
    background: linear-gradient(90deg, rgba(212,169,75,0.18), rgba(212,169,75,0.08));
    color: var(--color-gold);
    border: 0.5px solid rgba(212,169,75,0.4);
    width: fit-content;
    animation: pulse-gold 2.5s infinite;
}
@keyframes pulse-gold {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212,169,75,0); }
    50%       { box-shadow: 0 0 0 5px rgba(212,169,75,0.08); }
}

/* Prix */
.pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
}
.pricing-card__amount {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: #F0F2F7;
    letter-spacing: -0.04em;
    line-height: 1;
}
.pricing-card__amount--premium {
    font-size: 2rem;
    color: var(--color-gold);
}
.pricing-card__period {
    font-size: 13px;
    color: var(--color-text-faint);
    font-weight: 300;
}
.pricing-card__desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-text-muted);
    font-weight: 300;
}

/* Features */
.pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1;
}
.pricing-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.5;
}
.pricing-card__feature--disabled {
    opacity: 0.35;
}
.pricing-card__check {
    color: var(--color-accent);
    font-size: 15px;
    flex-shrink: 0;
    margin-top: 1px;
}
.pricing-card__check--gold {
    color: var(--color-gold);
}
.pricing-card__cross {
    color: var(--color-text-faint);
    font-size: 15px;
    flex-shrink: 0;
    margin-top: 1px;
}

.pricing-card__limited-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 100px;
    background: rgba(212,169,75,0.12);
    color: var(--color-gold);
    border: 0.5px solid rgba(212,169,75,0.3);
    white-space: nowrap;
    flex-shrink: 0;
}

/* CTA */
.pricing-card__cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.pricing-card__btn {
    width: 100%;
    text-align: center;
    justify-content: center;
}
.pricing-card__note {
    font-size: 11.5px;
    color: var(--color-text-faint);
    text-align: center;
    font-weight: 300;
}
.pricing-card__already-premium {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--color-gold);
    font-size: 14px;
    font-weight: 600;
    padding: 0.8rem;
    background: var(--color-gold-dim);
    border: 0.5px solid rgba(212,169,75,0.25);
    border-radius: var(--radius-md);
}

/* ── FAQ ── */
.pricing-faq {
    border-top: 0.5px solid var(--color-border);
    padding-top: 4rem;
}
.pricing-faq__title {
    text-align: center;
    margin-bottom: 2.5rem;
    font-size: 1.6rem;
}
.pricing-faq__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
}
.pricing-faq__item {
    background: var(--color-bg-2);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
}
.pricing-faq__q {
    font-size: 14px;
    font-weight: 600;
    color: #F0F2F7;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
}
.pricing-faq__q i {
    color: var(--color-accent);
    font-size: 15px;
    flex-shrink: 0;
}
.pricing-faq__a {
    font-size: 13px;
    line-height: 1.65;
    color: var(--color-text-faint);
    font-weight: 300;
}

/* Responsive */
@media (max-width: 800px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-faq__grid { grid-template-columns: 1fr; }
    .pricing-card--premium { margin-top: 1rem; }
}
@media (max-width: 500px) {
    .pricing-card { padding: 1.8rem; }
    .pricing-card__amount { font-size: 2.2rem; }
}
</style>
{% endblock %}
