{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}
{% block meta_description %}Développement fullstack sur mesure & Trading algorithmique. Applications métier Symfony, gestion immobilière, algo de trading ICT/Quant.{% endblock %}

{% block body %}

{# ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ #}
<section class="hero">
    <div class="hero__inner">
        <div class="hero__content">
            <div class="hero__tag">
                <span class="hero__tag-dot"></span>
                Développeur Fullstack &amp; Trader Quantitatif
            </div>

            <h1 class="hero__title">
                Solutions web<br>
                <em class="hero__title-accent">et stratégies</em><br>
                qui performent.
            </h1>

            <p class="hero__sub">
                Applications métier sur mesure, gestion immobilière, et outils de trading algorithmique.
                Des systèmes pensés pour durer et produire des résultats concrets.
            </p>

            <div class="hero__actions">
                <a href="{{ path('app_portfolio') }}" class="btn btn--primary">Voir les prestations</a>
                <a href="{{ path('app_trading') }}" class="btn btn--ghost">Découvrir l'algo</a>
            </div>
        </div>

        <div class="hero__stats">
            <div class="hero__stat">
                <span class="hero__stat-val">5<span class="hero__stat-plus">+</span></span>
                <span class="hero__stat-label">Projets fullstack livrés</span>
            </div>
            <div class="hero__stat">
                <span class="hero__stat-val">3<span class="hero__stat-plus">ans</span></span>
                <span class="hero__stat-label">Expérience Symfony</span>
            </div>
            <div class="hero__stat">
                <span class="hero__stat-val">ICT<span class="hero__stat-plus">/QF</span></span>
                <span class="hero__stat-label">Méthodologie de trading</span>
            </div>
        </div>
    </div>
</section>

<hr class="divider">

{# ══════════════════════════════════════════
   PRESTATIONS
══════════════════════════════════════════ #}
<section class="section">
    <span class="section-eyebrow">Développement</span>
    <h2>Prestations & Portfolio</h2>
    <p class="section-desc">
        Applications fullstack sur mesure — du backend Symfony robuste au frontend soigné,
        avec une vraie logique métier embarquée.
    </p>

    <div class="services-grid">

        <div class="service-card">
            <div class="service-card__type">Fullstack — Web App</div>
            <h3 class="service-card__title">Gestion immobilière</h3>
            <p class="service-card__desc">
                Gestion de biens, locataires, contrats et quittances. Tableau de bord analytique,
                relances automatisées et espace propriétaire sécurisé.
            </p>
            <div class="service-card__tags">
                <span class="tag tag--accent">Symfony 6</span>
                <span class="tag">Twig</span>
                <span class="tag">PostgreSQL</span>
                <span class="tag">PDF</span>
            </div>
        </div>

        <div class="service-card">
            <div class="service-card__type">Fullstack — Site vitrine</div>
            <h3 class="service-card__title">Site corporate + espace client</h3>
            <p class="service-card__desc">
                Site institutionnel avec back-office sur mesure, gestion de contenus,
                formulaires métier et espace client sécurisé par JWT.
            </p>
            <div class="service-card__tags">
                <span class="tag tag--accent">Symfony</span>
                <span class="tag">API REST</span>
                <span class="tag">Auth JWT</span>
                <span class="tag">CI/CD</span>
            </div>
        </div>

        <div class="service-card">
            <div class="service-card__type">Fullstack — SaaS</div>
            <h3 class="service-card__title">Application métier sur mesure</h3>
            <p class="service-card__desc">
                Solution verticale DDD, rôles et permissions granulaires,
                reporting exportable, architecture scalable et dockerisée.
            </p>
            <div class="service-card__tags">
                <span class="tag tag--accent">DDD</span>
                <span class="tag">Messenger</span>
                <span class="tag">Docker</span>
                <span class="tag">Redis</span>
            </div>
        </div>

    </div>

    <div class="section-cta">
        <a href="{{ path('app_portfolio') }}" class="btn btn--ghost">Voir tous les projets →</a>
    </div>
</section>

<hr class="divider">

{# ══════════════════════════════════════════
   ALGO TRADING
══════════════════════════════════════════ #}
<section class="section">
    <div class="algo-block">
        <div class="algo-block__content">
            <span class="section-eyebrow">Trading Algorithmique</span>
            <div class="algo-block__badge">Bientôt disponible</div>
            <h2 class="algo-block__title">Un algo pensé pour les marchés d'aujourd'hui.</h2>
            <p class="algo-block__desc">
                Stratégie quantitative construite autour des concepts ICT, de l'analyse de l'orderflow
                et de modèles statistiques robustes. Backtesté sur plus de 3 ans de données réelles.
            </p>

            <div class="algo-metrics">
                <div class="algo-metric">
                    <span class="algo-metric__val">+68%</span>
                    <span class="algo-metric__label">Rendement annualisé (backtest)</span>
                </div>
                <div class="algo-metric">
                    <span class="algo-metric__val">1.87</span>
                    <span class="algo-metric__label">Sharpe Ratio</span>
                </div>
                <div class="algo-metric">
                    <span class="algo-metric__val">&lt;12%</span>
                    <span class="algo-metric__label">Drawdown max</span>
                </div>
            </div>

            <div class="waitlist-form" id="waitlist-form">
                <input type="email" class="form-control waitlist-form__input" placeholder="votre@email.com" id="waitlist-email">
                <button class="btn btn--primary" onclick="submitWaitlist()">Rejoindre la waitlist</button>
            </div>
            <p class="waitlist-note">Notification à la sortie — aucun spam.</p>
        </div>

        <div class="algo-block__decoration" aria-hidden="true">
            ALGO
        </div>
    </div>
</section>

<hr class="divider">

{# ══════════════════════════════════════════
   DOCUMENTATION TRADING
══════════════════════════════════════════ #}
<section class="section">
    <span class="section-eyebrow">Ressources & Documentation</span>
    <h2>Maîtrisez les marchés</h2>
    <p class="section-desc">
        De la théorie ICT aux modèles quantitatifs — une documentation structurée
        pour traders sérieux.
    </p>

    <div class="doc-grid">

        <div class="doc-card">
            <div class="doc-card__icon">📐</div>
            <div class="doc-card__body">
                <h3 class="doc-card__title">ICT — Inner Circle Trader</h3>
                <p class="doc-card__desc">
                    Fair Value Gaps, Order Blocks, liquidity sweeps, kill zones et modèles Smart Money.
                </p>
            </div>
            <span class="tag tag--accent">Accès gratuit</span>
        </div>

        <div class="doc-card">
            <div class="doc-card__icon">📊</div>
            <div class="doc-card__body">
                <h3 class="doc-card__title">Orderflow & Footprint</h3>
                <p class="doc-card__desc">
                    Lecture du carnet d'ordres, delta cumulé, absorption et imbalances tick par tick.
                </p>
            </div>
            <span class="tag tag--gold">Premium</span>
        </div>

        <div class="doc-card">
            <div class="doc-card__icon">🎯</div>
            <div class="doc-card__body">
                <h3 class="doc-card__title">Price Action avancée</h3>
                <p class="doc-card__desc">
                    Structure de marché, BOS/CHoCH, Wyckoff, session profiles et confluences MTF.
                </p>
            </div>
            <span class="tag tag--accent">Accès gratuit</span>
        </div>

        <div class="doc-card">
            <div class="doc-card__icon">📉</div>
            <div class="doc-card__body">
                <h3 class="doc-card__title">Quant & Statistiques</h3>
                <p class="doc-card__desc">
                    STDV, distributions, backtesting rigoureux, Monte Carlo et optimisation de stratégies.
                </p>
            </div>
            <span class="tag tag--gold">Premium</span>
        </div>

    </div>

    <div class="section-cta">
        <a href="{{ path('app_documentation') }}" class="btn btn--ghost">Explorer la documentation →</a>
    </div>
</section>

{% endblock %}

{% block stylesheets %}
<style>
/* ── Hero ── */
.hero {
    width: 100%;
    padding: 7rem var(--section-px) 5rem;
    max-width: var(--max-width);
    margin: 0 auto;
}

.hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 0.5px solid var(--color-accent-border);
    border-radius: 100px;
    padding: 0.35rem 1rem;
    margin-bottom: 2rem;
}

.hero__tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse 2s infinite;
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}

.hero__title {
    margin-bottom: 1.5rem;
}
.hero__title-accent { font-style: normal; color: var(--color-accent); }

.hero__sub {
    max-width: 560px;
    font-size: 1.05rem;
    font-weight: 300;
    margin-bottom: 2.5rem;
    line-height: 1.7;
}

.hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.hero__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 5rem;
}

.hero__stat {
    padding: 1.8rem 2rem;
    background: rgba(255,255,255,0.02);
    border-right: 0.5px solid var(--color-border);
}
.hero__stat:last-child { border-right: none; }

.hero__stat-val {
    display: block;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: #F0F2F7;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.4rem;
}
.hero__stat-plus {
    font-size: 1.1rem;
    color: var(--color-accent);
}
.hero__stat-label {
    font-size: 13px;
    color: var(--color-text-faint);
    font-weight: 300;
}

/* ── Services grid ── */
.services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}

.service-card {
    background: var(--color-bg-2);
    padding: 2.2rem;
    transition: background var(--transition);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
}
.service-card:hover { background: var(--color-bg-3); }

.service-card__type {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
}

.service-card__title {
    color: #F0F2F7;
    font-size: 1.15rem;
}

.service-card__desc {
    font-size: 13.5px;
    line-height: 1.65;
    flex: 1;
}

.service-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 0.5rem;
}

/* ── Section CTA ── */
.section-cta {
    margin-top: 2.5rem;
}

/* ── Algo block ── */
.algo-block {
    background: linear-gradient(135deg, rgba(62,180,137,0.05) 0%, transparent 60%);
    border: 0.5px solid rgba(62, 180, 137, 0.12);
    border-radius: var(--radius-xl);
    padding: 4rem;
    position: relative;
    overflow: hidden;
}

.algo-block__decoration {
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 800;
    color: rgba(62, 180, 137, 0.04);
    pointer-events: none;
    letter-spacing: -0.05em;
    user-select: none;
}

.algo-block__badge {
    display: inline-block;
    background: var(--color-accent-dim);
    color: var(--color-accent);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    border: 0.5px solid var(--color-accent-border);
    margin-bottom: 1.5rem;
}

.algo-block__title {
    max-width: 540px;
    margin-bottom: 1rem;
}

.algo-block__desc {
    max-width: 560px;
    margin-bottom: 2rem;
    font-weight: 300;
    line-height: 1.7;
}

.algo-metrics {
    display: flex;
    gap: 3rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
}

.algo-metric__val {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.03em;
}

.algo-metric__label {
    display: block;
    font-size: 12px;
    color: var(--color-text-faint);
    margin-top: 2px;
}

.waitlist-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    max-width: 480px;
}

.waitlist-form__input {
    flex: 1;
    min-width: 220px;
}

.waitlist-note {
    font-size: 12px;
    color: var(--color-text-faint);
    margin-top: 0.6rem;
    font-weight: 300;
}

/* ── Doc grid ── */
.doc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
}

.doc-card {
    background: rgba(255,255,255,0.02);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color var(--transition);
}
.doc-card:hover { border-color: var(--color-border-md); }

.doc-card__icon {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    background: var(--color-accent-dim);
    border: 0.5px solid var(--color-accent-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
}

.doc-card__body { flex: 1; }

.doc-card__title {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    color: #F0F2F7;
}

.doc-card__desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-faint);
}

/* ── Responsive home ── */
@media (max-width: 900px) {
    .hero__stats { grid-template-columns: 1fr; }
    .hero__stat { border-right: none; border-bottom: 0.5px solid var(--color-border); }
    .hero__stat:last-child { border-bottom: none; }
    .services-grid { grid-template-columns: 1fr; }
    .doc-grid { grid-template-columns: repeat(2, 1fr); }
    .algo-block { padding: 2.5rem; }
    .algo-block__decoration { display: none; }
}

@media (max-width: 600px) {
    .hero { padding-top: 4rem; }
    .hero__stats { grid-template-columns: 1fr; }
    .doc-grid { grid-template-columns: 1fr; }
    .algo-metrics { gap: 1.5rem; }
    .waitlist-form { flex-direction: column; }
}
</style>
{% endblock %}

{% block javascripts %}
<script>
function submitWaitlist() {
    const email = document.getElementById('waitlist-email').value.trim();
    if (!email || !email.includes('@')) {
        alert('Veuillez entrer un email valide.');
        return;
    }

    fetch('{{ path("app_trading_waitlist") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ email: email, source: 'homepage' })
    })
    .then(r => r.json())
    .then(data => {
        const form = document.getElementById('waitlist-form');
        form.innerHTML = '<p style="color: var(--color-accent); font-size: 14px;">✓ Vous êtes sur la liste — on vous contacte à la sortie.</p>';
    })
    .catch(() => {
        alert('Une erreur est survenue. Réessayez.');
    });
}
</script>
{% endblock %}
